{
  "uid": "rag-platform",
  "title": "RAG Platform",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 36,
  "tags": ["rag", "platform"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "type": "datasource", "name": "Prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(rag_requests_total[5m])",
          "legendFormat": "{{endpoint}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(rag_requests_total{status_code=~\"5..\"}[5m])",
          "legendFormat": "5xx errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency p50/p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(rag_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Retrieval vs Generation Latency p50",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(rag_retrieval_duration_seconds_bucket[5m]))",
          "legendFormat": "retrieval p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.5, rate(rag_generation_duration_seconds_bucket[5m]))",
          "legendFormat": "generation p50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Chunks Retrieved",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(rag_chunks_retrieved_total_sum[5m])",
          "legendFormat": "chunks",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Token Usage Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(rag_tokens_total[5m])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Estimated Cost (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rag_cost_usd_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 8,
      "title": "Documents Ingested",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rag_documents_ingested_total",
          "legendFormat": "{{chunking_strategy}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Faithfulness",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 24, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rag_evaluation_scores{metric=\"faithfulness\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 10,
      "title": "Answer Relevancy",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 24, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rag_evaluation_scores{metric=\"answer_relevancy\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 11,
      "title": "Context Recall",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 24, "w": 4, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rag_evaluation_scores{metric=\"context_recall\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    }
  ]
}
