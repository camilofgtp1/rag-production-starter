# OpenAI Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Qdrant Vector Database Configuration
# URL of your Qdrant instance (local: http://localhost:6333, cloud: https://your-cluster.qdrant.cloud)
QDRANT_URL=http://localhost:6333
# API key for Qdrant cloud (leave empty for local)
QDRANT_API_KEY=your-qdrant-api-key-here

# MLflow Tracking Server
# URI for MLflow tracking (local: http://localhost:5000, cloud: https://your-mlflow.qryn.cloud)
MLFLOW_TRACKING_URI=http://localhost:5000

# Application API Key
# Used for authentication on all non-health routes
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-secure-api-key-here

# Qdrant Collection Name
# Name of the vector collection to use
COLLECTION_NAME=rag_collection